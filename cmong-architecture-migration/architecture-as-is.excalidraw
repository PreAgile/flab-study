    {
      "id": "el_501716785",
      "type": "text",
      "x": 785,
      "y": 570,
      "width": 367.2,
      "height": 75.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
