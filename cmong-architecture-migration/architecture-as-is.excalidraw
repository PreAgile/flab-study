      "seed": 758040849,
      "version": 1,
      "versionNonce": 757697645,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779113427996,
      "link": null,
      "locked": false,
      "text": "동시 1,000건 처리 시 1,000개 소켓이 5분간 잠긴다.\nALB idle timeout(60s) 도달 → 응답은 버려지지만 스크래퍼는 계속 일함 (멱등성 깨짐)",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "동시 1,000건 처리 시 1,000개 소켓이 5분간 잠긴다.\nALB idle timeout(60s) 도달 → 응답은 버려지지만 스크래퍼는 계속 일함 (멱등성 깨짐)",
      "lineHeight": 1.25,
      "autoResize": true
    },
